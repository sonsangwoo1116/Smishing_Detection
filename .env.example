# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4-mini

# Google Web Risk API
GOOGLE_WEB_RISK_API_KEY=your-web-risk-api-key

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://smishing:smishing@localhost:5432/smishing_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000

# API Key (초기 부트스트랩용 시드 키, 이후 DB에서 관리)
INITIAL_API_KEY=your-bootstrap-api-key

# Cache (안전 판정 URL TTL. 위협 판정은 자동 1시간)
URL_CACHE_TTL_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
